  },
  "Jwt": {
    "Issuer": "PortfolioManagement",
    "Audience": "PortfolioManagement",
    "Secret": "CHANGE_ME_TO_A_64_CHARACTER_SECRET_FOR_PRODUCTION_ENVIRONMENTS",
